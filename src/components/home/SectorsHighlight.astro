---
import SectorCard from '@/components/ui/SectorCard.astro';

interface Sector {
  titulo: string;
  slug: string;
  descripcionCorta?: string;
  imagenUrl?: string;
}

interface Props {
  titulo?: string;
  sectores: Sector[];
}

const { titulo = 'Sectores de actividad', sectores = [] } = Astro.props;
---
<section class="py-24 lg:py-32 max-w-7xl mx-auto px-6 lg:px-12">
  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
    <div>
      <p class="text-firm-gold text-xs font-sans uppercase tracking-[0.2em] mb-3">Sectores</p>
      <h2 class="font-serif text-4xl lg:text-5xl font-light">{titulo}</h2>
    </div>
    <a href="/sectores" class="text-xs font-sans uppercase tracking-[0.2em] link-underline hover:text-firm-gold transition-colors self-start md:self-auto">
      Ver todos →
    </a>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {sectores.map((s) => (
      <SectorCard {...s} />
    ))}
  </div>
</section>
