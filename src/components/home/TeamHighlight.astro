---
import TeamCard from '@/components/ui/TeamCard.astro';

interface Miembro {
  nombre: string;
  slug: string;
  cargo?: string;
  categoria?: string;
  fotoUrl?: string;
  especialidades?: string[];
}

interface Props {
  titulo?: string;
  miembros: Miembro[];
}

const { titulo = 'Nuestro equipo', miembros = [] } = Astro.props;
---
<section class="py-24 lg:py-32 bg-firm-white border-t border-firm-border">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
      <div>
        <p class="text-firm-gold text-xs font-sans uppercase tracking-[0.2em] mb-3">Equipo</p>
        <h2 class="font-serif text-4xl lg:text-5xl font-light">{titulo}</h2>
      </div>
      <a href="/equipo" class="text-xs font-sans uppercase tracking-[0.2em] link-underline hover:text-firm-gold transition-colors self-start md:self-auto">
        Conocer el equipo →
      </a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 lg:gap-8">
      {miembros.map((m) => (
        <TeamCard {...m} />
      ))}
    </div>
  </div>
</section>
