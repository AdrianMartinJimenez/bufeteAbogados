---
interface Props {
  titulo?: string;
  subtitulo?: string;
  boton1Texto?: string;
  boton1Enlace?: string;
  boton2Texto?: string;
  boton2Enlace?: string;
}

const {
  titulo = '¿Necesita asesoramiento jurídico?',
  subtitulo = 'Nuestro equipo está a su disposición para atender su consulta con la máxima discreción y profesionalidad.',
  boton1Texto = 'Contactar con el despacho',
  boton1Enlace = '/contacto',
  boton2Texto = 'Conocer el equipo',
  boton2Enlace = '/equipo',
} = Astro.props;
---
<section class="py-24 lg:py-32 bg-firm-black text-firm-white">
  <div class="max-w-4xl mx-auto px-6 lg:px-12 text-center">
    <h2 class="font-serif text-4xl lg:text-6xl font-light leading-tight mb-6">{titulo}</h2>
    <p class="font-sans text-white/60 text-lg leading-relaxed mb-12 max-w-2xl mx-auto">{subtitulo}</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={boton1Enlace}
        class="inline-flex items-center gap-3 bg-firm-gold text-firm-black text-xs font-sans uppercase tracking-[0.2em] px-10 py-4 hover:bg-white transition-colors duration-200"
      >
        {boton1Texto}
      </a>
      {boton2Texto && boton2Enlace && (
        <a
          href={boton2Enlace}
          class="inline-flex items-center gap-3 border border-white/30 text-white text-xs font-sans uppercase tracking-[0.2em] px-8 py-4 hover:border-white hover:bg-white/10 transition-all duration-200"
        >
          {boton2Texto}
        </a>
      )}
    </div>
  </div>
</section>
