---
interface Props {
  titulo: string;
  slug: string;
  descripcionCorta?: string;
  icono?: string;
  imagenUrl?: string;
}

const { titulo, slug, descripcionCorta, icono } = Astro.props;
---
<a href={`/servicios/${slug}`} class="group block card-gold-top border border-firm-border p-8 transition-colors hover:border-firm-gold/40 relative">
  {icono && (
    <span class="font-serif text-5xl text-firm-muted/30 block mb-4 transition-colors group-hover:text-firm-gold/40" aria-hidden="true">
      {icono}
    </span>
  )}
  <h3 class="font-serif text-xl font-light uppercase tracking-wide mb-3 group-hover:text-firm-gold transition-colors">
    {titulo}
  </h3>
  {descripcionCorta && (
    <p class="text-firm-muted text-sm font-sans leading-relaxed line-clamp-3">{descripcionCorta}</p>
  )}
  <span class="inline-block mt-6 text-xs font-sans uppercase tracking-[0.15em] text-firm-muted group-hover:text-firm-gold group-hover:translate-x-1 transition-all duration-200">
    Ver servicio →
  </span>
</a>
