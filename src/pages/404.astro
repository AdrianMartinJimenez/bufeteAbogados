---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout seo={{ titulo: 'Página no encontrada' }}>
  <section class="min-h-[70vh] flex items-center justify-center">
    <div class="text-center px-6">
      <p class="font-serif text-[8rem] lg:text-[12rem] font-light text-firm-border leading-none mb-4" aria-hidden="true">
        404
      </p>
      <h1 class="font-serif text-3xl lg:text-4xl font-light mb-4">Página no encontrada</h1>
      <p class="font-sans text-firm-muted mb-10 max-w-md mx-auto">
        La página que busca no existe o ha sido movida. Vuelva a la página de inicio o utilice la navegación para encontrar lo que necesita.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center gap-2 border border-firm-black px-8 py-3.5 text-xs font-sans uppercase tracking-[0.2em] hover:bg-firm-black hover:text-white transition-all duration-200"
        >
          Ir al inicio
        </a>
        <a
          href="/contacto"
          class="inline-flex items-center gap-2 text-xs font-sans uppercase tracking-[0.2em] text-firm-muted hover:text-firm-gold transition-colors"
        >
          Contacto →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
