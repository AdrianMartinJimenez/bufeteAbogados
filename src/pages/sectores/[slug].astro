---
import PageLayout from '@/layouts/PageLayout.astro';
import PortableText from '@/components/ui/PortableText.astro';
import CtaSection from '@/components/home/CtaSection.astro';
import { getSectorBySlug } from '@/lib/queries';

const { slug } = Astro.params;
const sector = await getSectorBySlug(slug!);

if (!sector) return Astro.redirect('/sectores', 301);
---
<PageLayout
  titulo={sector.titulo}
  subtitulo="Sector"
  seo={{ titulo: sector.seoTitulo ?? sector.titulo, descripcion: sector.seoDescripcion }}
>
  {sector.descripcionCorta && (
    <p class="text-xl font-sans text-firm-muted leading-relaxed mb-12 max-w-2xl">{sector.descripcionCorta}</p>
  )}

  {sector.contenido && (
    <div class="max-w-3xl">
      <PortableText content={sector.contenido} />
    </div>
  )}

  <div class="mt-16 pt-8 border-t border-firm-border">
    <a href="/sectores" class="text-xs font-sans uppercase tracking-[0.2em] text-firm-muted hover:text-firm-gold transition-colors">
      ← Volver a Sectores
    </a>
  </div>
</PageLayout>

<CtaSection />
