---
import PageLayout from '@/layouts/PageLayout.astro';
import ArticleCard from '@/components/ui/ArticleCard.astro';
import Pagination from '@/components/ui/Pagination.astro';
import { getArticulos } from '@/lib/queries';

const pageParam = Number(Astro.params.page);
const page = isNaN(pageParam) || pageParam < 1 ? 1 : pageParam;
const { items, totalPages } = await getArticulos(page);
---
<PageLayout titulo="Conocimiento" subtitulo={`Página ${page}`}>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12">
    {items.map((a: any) => (
      <ArticleCard
        titulo={a.titulo}
        slug={a.slug}
        fechaPublicacion={a.fechaPublicacion}
        categorias={a.categorias}
        extracto={a.extracto}
        imagenUrl={a.imagenUrl}
        autorNombre={a.autorNombre}
      />
    ))}
  </div>
  <Pagination currentPage={page} totalPages={totalPages} baseUrl="/conocimiento/pagina" firstPageUrl="/conocimiento" />
</PageLayout>
