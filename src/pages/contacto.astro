---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContactForm from '@/components/interactive/ContactForm';

const oficinas = [
  {
    ciudad: 'Madrid',
    direccion: 'Calle Serrano, 41, 3ª planta',
    cp: '28001 Madrid',
    telefono: '+34 91 000 00 00',
    email: 'madrid@despacho.com',
  },
  {
    ciudad: 'Las Palmas de Gran Canaria',
    direccion: 'Calle León y Castillo, 54',
    cp: '35003 Las Palmas de G.C.',
    telefono: '+34 928 000 000',
    email: 'laspalmas@despacho.com',
  },
  {
    ciudad: 'London',
    direccion: '22 Chancery Lane',
    cp: 'WC2A 1LS London',
    telefono: '+44 20 0000 0000',
    email: 'london@despacho.com',
  },
];
---
<BaseLayout seo={{ titulo: 'Contacto', descripcion: 'Contacte con nuestro despacho. Oficinas en Madrid, Las Palmas de Gran Canaria y Londres.' }}>
  <!-- Cabecera -->
  <section class="bg-firm-black text-firm-white py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <p class="text-firm-gold text-xs font-sans uppercase tracking-[0.2em] mb-4">Contacto</p>
      <h1 class="font-serif text-5xl lg:text-7xl font-light">¿Hablamos?</h1>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-16 lg:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">

      <!-- Formulario -->
      <div>
        <h2 class="font-serif text-3xl font-light mb-10">Envíenos su consulta</h2>
        <ContactForm client:load />
      </div>

      <!-- Oficinas -->
      <div>
        <h2 class="font-serif text-3xl font-light mb-10">Nuestras oficinas</h2>
        <div class="space-y-10">
          {oficinas.map((o) => (
            <div class="border-l-2 border-firm-gold pl-6">
              <p class="text-xs font-sans uppercase tracking-[0.2em] text-firm-gold mb-3">{o.ciudad}</p>
              <p class="font-sans text-sm text-firm-muted leading-relaxed">{o.direccion}</p>
              <p class="font-sans text-sm text-firm-muted">{o.cp}</p>
              <div class="mt-3 space-y-1">
                <a href={`tel:${o.telefono.replace(/\s/g, '')}`} class="block font-sans text-sm hover:text-firm-gold transition-colors">
                  {o.telefono}
                </a>
                <a href={`mailto:${o.email}`} class="block font-sans text-sm hover:text-firm-gold transition-colors">
                  {o.email}
                </a>
              </div>
            </div>
          ))}
        </div>

        <!-- Nota legal -->
        <p class="mt-12 text-xs font-sans text-firm-muted leading-relaxed border-t border-firm-border pt-6">
          De conformidad con el Reglamento (UE) 2016/679 (RGPD) y la LOPDGDD, le informamos que los datos facilitados serán tratados por el despacho con la finalidad de atender su consulta. Puede ejercer sus derechos en la dirección de correo electrónico indicada o consultando nuestra{' '}
          <a href="/politica-privacidad" class="text-firm-gold hover:underline">Política de Privacidad</a>.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
