---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSectorById, updateSector } from '../../../lib/queries';

const id = Number(Astro.params.id);
if (!id) return Astro.redirect('/admin/sectores');

let error = '';
if (Astro.request.method === 'POST') {
  try {
    const form = await Astro.request.formData();
    await updateSector(id, {
      titulo: form.get('titulo'), slug: form.get('slug'),
      descripcionCorta: form.get('descripcion_corta'), imagenUrl: form.get('imagen_url'),
      colorAccento: form.get('color_acento') || '#C9A84C',
      contenido: form.get('contenido'), orden: Number(form.get('orden') ?? 0),
      seoTitulo: form.get('seo_titulo'), seoDescripcion: form.get('seo_descripcion'),
    });
    return Astro.redirect('/admin/sectores');
  } catch (e: any) { error = e.message ?? 'Error al guardar'; }
}

const s = await getSectorById(id);
if (!s) return Astro.redirect('/admin/sectores');
---
<AdminLayout title={`Editar: ${s.titulo}`}>
  <style>
    form { max-width: 700px; }
    .section-title { font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: #6B6B6B; border-bottom: 1px solid #E2E0DB; padding-bottom: 0.5rem; margin: 2rem 0 1.25rem; }
    .section-title:first-of-type { margin-top: 0; }
    .field { margin-bottom: 1.25rem; }
    label { display: block; font-size: 0.75rem; font-weight: 500; color: #0A0A0A; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.4rem; }
    label small { text-transform: none; letter-spacing: normal; font-weight: 400; color: #6B6B6B; }
    input[type="text"], input[type="url"], input[type="number"], input[type="color"], textarea {
      width: 100%; background: transparent; border: none; border-bottom: 1px solid #E2E0DB;
      padding: 0.5rem 0; font-size: 0.9375rem; color: #0A0A0A; outline: none;
      transition: border-color 0.2s; font-family: 'Inter', sans-serif;
    }
    input[type="color"] { height: 2rem; padding: 0; cursor: pointer; }
    input:focus, textarea:focus { border-color: #0A0A0A; }
    textarea { resize: vertical; min-height: 120px; }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
    .error-msg { background: #FEF2F2; border: 1px solid #FCA5A5; color: #991B1B; padding: 0.75rem 1rem; font-size: 0.8125rem; margin-bottom: 1.5rem; }
    .actions { display: flex; gap: 1rem; align-items: center; margin-top: 1.5rem; }
    .btn-save { background: #0A0A0A; color: #F8F7F4; border: none; padding: 0.875rem 2rem; font-size: 0.8125rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer; font-family: 'Inter', sans-serif; }
    .btn-save:hover { opacity: 0.85; }
    .btn-cancel { color: #6B6B6B; text-decoration: none; font-size: 0.8125rem; }
    .preview-link { font-size: 0.8125rem; color: #C9A84C; text-decoration: none; }
  </style>

  {error && <div class="error-msg">{error}</div>}
  <div style="margin-bottom:1rem"><a href={`/sectores/${s.slug}`} target="_blank" class="preview-link">Ver en el sitio ↗</a></div>

  <form method="POST">
    <p class="section-title">Información principal</p>
    <div class="field"><label>Título *</label><input type="text" name="titulo" value={s.titulo} required /></div>
    <div class="field"><label>Slug *</label><input type="text" name="slug" value={s.slug} required pattern="[a-z0-9\-]+" /></div>
    <div class="field"><label>Descripción corta</label><textarea name="descripcion_corta" style="min-height:60px">{s.descripcionCorta ?? ''}</textarea></div>
    <div class="grid-2">
      <div class="field"><label>Imagen (URL)</label><input type="url" name="imagen_url" value={s.imagenUrl ?? ''} /></div>
      <div class="field"><label>Color acento</label><input type="color" name="color_acento" value={s.colorAccento ?? '#C9A84C'} /></div>
    </div>
    <div class="field"><label>Contenido <small>(Markdown)</small></label><textarea name="contenido" style="min-height:200px">{s.contenido ?? ''}</textarea></div>
    <div class="field"><label>Orden</label><input type="number" name="orden" value={s.orden ?? 0} min="0" style="max-width:120px" /></div>

    <p class="section-title">SEO</p>
    <div class="field"><label>Título SEO</label><input type="text" name="seo_titulo" value={s.seoTitulo ?? ''} /></div>
    <div class="field"><label>Descripción SEO</label><textarea name="seo_descripcion" style="min-height:60px">{s.seoDescripcion ?? ''}</textarea></div>

    <div class="actions">
      <button type="submit" class="btn-save">Guardar cambios</button>
      <a href="/admin/sectores" class="btn-cancel">Cancelar</a>
    </div>
  </form>
</AdminLayout>
