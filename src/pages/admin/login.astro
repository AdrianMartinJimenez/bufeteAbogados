---
import { verifyPassword } from '../../lib/auth';
import { authCookie, createToken } from '../../lib/auth';
import { getUserByEmail } from '../../lib/queries';

// Redirigir si ya hay sesión válida
const cookie = Astro.cookies.get('admin_token');
if (cookie?.value) {
  const { verifyToken } = await import('../../lib/auth');
  const user = await verifyToken(cookie.value);
  if (user) return Astro.redirect('/admin');
}

let error = '';
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const email = String(form.get('email') ?? '').trim().toLowerCase();
  const password = String(form.get('password') ?? '');

  if (!email || !password) {
    error = 'Por favor, introduce email y contraseña.';
  } else {
    const dbUser = await getUserByEmail(email);
    if (!dbUser) {
      error = 'Email o contraseña incorrectos.';
    } else {
      const valid = await verifyPassword(password, dbUser.passwordHash);
      if (!valid) {
        error = 'Email o contraseña incorrectos.';
      } else {
        const token = await createToken(dbUser.id, dbUser.email);
        const cookieHeader = authCookie(token);
        Astro.response.headers.set('Set-Cookie', cookieHeader);
        return Astro.redirect('/admin');
      }
    }
  }
}
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Acceso · Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; font-family: 'Inter', sans-serif; background: #0A0A0A; }
    body { display: flex; align-items: center; justify-content: center; }
    .card {
      background: #F8F7F4; width: 100%; max-width: 400px;
      padding: 3rem 2.5rem; margin: 1rem;
    }
    .logo {
      font-size: 0.7rem; font-weight: 500;
      letter-spacing: 0.15em; text-transform: uppercase;
      color: #C9A84C; margin-bottom: 2rem;
    }
    h1 { font-size: 1.375rem; font-weight: 400; color: #0A0A0A; margin-bottom: 0.5rem; }
    p.subtitle { font-size: 0.8125rem; color: #6B6B6B; margin-bottom: 2rem; }
    label { display: block; font-size: 0.75rem; font-weight: 500; color: #0A0A0A;
            text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem; }
    input[type="email"], input[type="password"] {
      width: 100%; background: transparent; border: none;
      border-bottom: 1px solid #E2E0DB;
      padding: 0.625rem 0; font-size: 0.9375rem; color: #0A0A0A;
      outline: none; transition: border-color 0.2s;
      font-family: 'Inter', sans-serif;
    }
    input:focus { border-color: #0A0A0A; }
    .field { margin-bottom: 1.5rem; }
    .error {
      background: #FEF2F2; border: 1px solid #FCA5A5;
      color: #991B1B; padding: 0.75rem 1rem;
      font-size: 0.8125rem; margin-bottom: 1.5rem;
    }
    button {
      width: 100%; background: #0A0A0A; color: #F8F7F4;
      border: none; padding: 0.875rem; cursor: pointer;
      font-size: 0.8125rem; font-weight: 500;
      letter-spacing: 0.08em; text-transform: uppercase;
      transition: opacity 0.2s; font-family: 'Inter', sans-serif;
    }
    button:hover { opacity: 0.85; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">Panel de Administración</div>
    <h1>Acceso restringido</h1>
    <p class="subtitle">Introduce tus credenciales para continuar.</p>

    {error && <div class="error">{error}</div>}

    <form method="POST">
      <div class="field">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required autocomplete="email" />
      </div>
      <div class="field">
        <label for="password">Contraseña</label>
        <input type="password" id="password" name="password" required autocomplete="current-password" />
      </div>
      <button type="submit">Entrar</button>
    </form>
  </div>
</body>
</html>
